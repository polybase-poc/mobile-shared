# Mobile Team Code Owners
#
# This file defines code ownership for the mobile codebase.
# When a pull request modifies files in these directories, the specified
# teams will automatically be requested for review.
#
# Review requirements:
# - Platform-specific code: 1 reviewer from the platform team
# - Shared code: 2 reviewers (1 from iOS, 1 from Android)
#
# For more information: https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# iOS Platform Code
ios/**                           @polybase-poc/mobile-ios
*.swift                          @polybase-poc/mobile-ios
*.xcodeproj/**                   @polybase-poc/mobile-ios
*.xcworkspace/**                 @polybase-poc/mobile-ios
Podfile                          @polybase-poc/mobile-ios
Podfile.lock                     @polybase-poc/mobile-ios
ios/fastlane/**                  @polybase-poc/mobile-ios

# Android Platform Code
android/**                       @polybase-poc/mobile-android
*.kt                             @polybase-poc/mobile-android
*.java                           @polybase-poc/mobile-android
*.gradle                         @polybase-poc/mobile-android
gradle.properties                @polybase-poc/mobile-android
android/fastlane/**              @polybase-poc/mobile-android

# Shared/Cross-Platform Code (requires both platform reviewers)
shared/**                        @polybase-poc/mobile-ios @polybase-poc/mobile-android
src/shared/**                    @polybase-poc/mobile-ios @polybase-poc/mobile-android
common/**                        @polybase-poc/mobile-ios @polybase-poc/mobile-android

